<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>簡易筆記系統 - 基本版</title>
  <style>
    body { font-family: sans-serif; max-width: 600px; margin: 40px auto; padding: 0 20px; line-height: 1.6; }
    h1 { color: #333; }
    .note-card { border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 5px; background: #fafafa; position: relative; }
    .note-title { font-weight: bold; font-size: 1.2em; margin-bottom: 5px; }
    .note-date { color: #888; font-size: 0.8em; margin-bottom: 10px; }
    .note-content { font-size: 1em; white-space: pre-wrap; }
    .delete-btn { position: absolute; top: 15px; right: 15px; color: #d9534f; text-decoration: none; font-size: 0.9em; }
    .add-btn { display: inline-block; background: #0275d8; color: #fff; padding: 8px 15px; text-decoration: none; border-radius: 4px; margin-bottom: 20px; }
  </style>
</head>
<body>
  <h1>📝 我的筆記本 (基本版)</h1>
  <a href="/new" class="add-btn">+ 新增筆記</a>
  
  <% if (notes.length === 0) { %>
    <p>目前沒有任何筆記。</p>
  <% } else { %>
    <% notes.forEach(note => { %>
      <div class="note-card">
        <div class="note-title"><%= note.title %></div>
        <div class="note-date">發表日期: <%= note.createdAt %></div>
        <div class="note-content"><%= note.content %></div>
        <a href="/delete/<%= note.id %>" class="delete-btn" onclick="return confirm('確定要刪除這篇筆記嗎？')">刪除</a>
      </div>
    <% }) %>
  <% } %>
</body>
</html>
