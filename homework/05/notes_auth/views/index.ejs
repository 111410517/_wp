<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>簡易筆記系統 - 驗證版</title>
  <style>
    body { font-family: sans-serif; max-width: 600px; margin: 40px auto; padding: 0 20px; line-height: 1.6; }
    h1 { color: #333; }
    .header-bar { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 10px; margin-bottom: 20px; }
    .note-card { border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 5px; background: #fafafa; position: relative; }
    .note-title { font-weight: bold; font-size: 1.2em; margin-bottom: 5px; }
    .note-date { color: #888; font-size: 0.8em; margin-bottom: 10px; }
    .note-content { font-size: 1em; white-space: pre-wrap; }
    .delete-btn { position: absolute; top: 15px; right: 15px; color: #d9534f; text-decoration: none; font-size: 0.9em; }
    .add-btn { display: inline-block; background: #0275d8; color: #fff; padding: 8px 15px; text-decoration: none; border-radius: 4px; }
    .logout-link { color: #d9534f; text-decoration: none; }
  </style>
</head>
<body>
  <div class="header-bar">
    <h1>📝 我的筆記本</h1>
    <div>
      <% if (username) { %>
        歡迎，<strong><%= username %></strong>！ | <a href="/logout" class="logout-link">登出</a>
      <% } else { %>
        <a href="/login">請登入</a> | <a href="/register">註冊</a>
      <% } %>
    </div>
  </div>

  <% if (username) { %>
    <a href="/new" class="add-btn" style="margin-bottom: 20px;">+ 新增筆記</a>
    
    <% if (notes.length === 0) { %>
      <p>目前沒有任何筆記，點擊上方按鈕開始撰寫吧！</p>
    <% } else { %>
      <% notes.forEach(note => { %>
        <div class="note-card">
          <div class="note-title"><%= note.title %></div>
          <div class="note-date">發表日期: <%= note.createdAt %></div>
          <div class="note-content"><%= note.content %></div>
          <a href="/delete/<%= note.id %>" class="delete-btn" onclick="return confirm('確定要刪除這篇筆記嗎？')">刪除</a>
        </div>
      <% }) %>
    <% } %>
  <% } else { %>
    <p>您需要 <a href="/login">登入</a> 才能檢視與管理您的個人筆記。</p>
  <% } %>
</body>
</html>
